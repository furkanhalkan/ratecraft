{
  "name": "ratecraft",
  "version": "0.1.1",
  "description": "Framework-agnostic, TypeScript-first rate limiter for Node.js, Bun, and Deno",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "require": "./dist/adapters/express.cjs"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js",
      "require": "./dist/adapters/fastify.cjs"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "require": "./dist/adapters/hono.cjs"
    },
    "./h3": {
      "types": "./dist/adapters/h3.d.ts",
      "import": "./dist/adapters/h3.js",
      "require": "./dist/adapters/h3.cjs"
    },
    "./redis": {
      "types": "./dist/stores/redis.d.ts",
      "import": "./dist/stores/redis.js",
      "require": "./dist/stores/redis.cjs"
    },
    "./memcached": {
      "types": "./dist/stores/memcached.d.ts",
      "import": "./dist/stores/memcached.js",
      "require": "./dist/stores/memcached.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "bench": "vitest bench",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "rate-limiter",
    "rate-limiting",
    "throttle",
    "express",
    "fastify",
    "hono",
    "h3",
    "nitro",
    "nuxt",
    "middleware",
    "redis",
    "typescript",
    "bun",
    "deno"
  ],
  "author": "Furkan Alkan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/furkanhalkan/ratecraft"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "fastify-plugin": "^4.0.0 || ^5.0.0",
    "h3": ">=1.0.0",
    "hono": ">=3.0.0",
    "ioredis": ">=5.0.0",
    "memcached": ">=2.2.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "memcached": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "h3": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify-plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/express": "^4.17.25",
    "@types/memcached": "^2.2.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.0.0",
    "express": "^4.22.1",
    "fastify": "^5.7.2",
    "fastify-plugin": "^5.1.0",
    "h3": "2.0.1-rc.20",
    "hono": "^4.0.0",
    "ioredis": "^5.4.0",
    "memcached": "^2.2.2",
    "mitata": "^1.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
